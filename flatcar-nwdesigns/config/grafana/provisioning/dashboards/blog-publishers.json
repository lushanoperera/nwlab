      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "timestamp(last_over_time(claude_code_session_count_total[7d])) * 1000",
          "legendFormat": "{{service_instance_id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Last-run timestamp per site",
      "type": "stat"
    }
