{
  "__comment": "Blog Publisher observability dashboard. Assumes Claude Code native OpenTelemetry metrics are being remote-written into Prometheus by the otel-collector co-located on flatcar-nwdesigns (VM 104). The CC native metric names follow the 'claude_code_*' Prometheus-flavored convention (dots → underscores). Metric names used here: claude_code_session_count, claude_code_cost_usage_USD_total, claude_code_token_usage_tokens_total, claude_code_api_request_duration_seconds, claude_code_api_error. service.instance.id labels split per site (officinewordpress / ambrosianomilano / costanzogoldtraders). Exact metric and label names may need tweaking on first live data — see https://docs.claude.com/en/docs/claude-code/monitoring-usage.",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Number of Claude Code sessions started per site in the last 24h. Backs publisher run counts.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (service_instance_id) (increase(claude_code_session_count_total[24h]))",
          "legendFormat": "{{service_instance_id}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Run count per site (last 24h)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Successful vs failed Claude Code API requests. Failures approximated via claude_code_api_error_total.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "displayLabels": ["name", "value"],
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "showLegend": true
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(claude_code_api_request_total[24h])) - sum(increase(claude_code_api_error_total[24h]))",
          "legendFormat": "success",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(claude_code_api_error_total[24h]))",
          "legendFormat": "failure",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Success vs failure (last 24h)",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Total input + output tokens consumed per site over the dashboard time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
