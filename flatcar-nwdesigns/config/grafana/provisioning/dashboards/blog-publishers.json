      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (instance, type) (increase(claude_code_token_usage_tokens_total{instance=~\".*(officine|ambrosiano|costanzo).*\"}[$__range]))",
          "legendFormat": "{{instance}} / {{type}}",
          "range": true,
          "refId": "A"
        }
