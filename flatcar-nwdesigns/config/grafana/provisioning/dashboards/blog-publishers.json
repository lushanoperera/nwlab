      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "total",
          "range": true,
