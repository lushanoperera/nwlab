# Grafana — flatcar-nwdesigns (VM 104)
#
# Admin password for the bootstrap `admin` user. Set on first start; rotate
# from the Grafana UI afterward (Server Admin → Users) or by re-bootstrapping
# the container with this var changed.
#
# Pattern matches other nwlab stacks: bare ${VAR} interpolation in
# docker-compose.yml, real value lives in the on-host `.env` file (never
# committed). No varlock/rbw in this repo.
GRAFANA_ADMIN_PASSWORD=changeme
