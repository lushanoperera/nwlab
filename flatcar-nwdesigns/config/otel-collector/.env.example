# OpenTelemetry Collector — flatcar-nwdesigns (VM 104)
#
# Remote-write target for metrics. Default points at the Prometheus container
# co-located on this same host via the shared `observability` Docker bridge
# network — `http://prometheus:9090/api/v1/write`. Override here only if
# Prometheus moves off-host (e.g. testing against a remote backend).
PROMETHEUS_REMOTE_WRITE_URL=http://prometheus:9090/api/v1/write
