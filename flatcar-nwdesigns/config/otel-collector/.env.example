# OpenTelemetry Collector — flatcar-nwdesigns (VM 104)
#
# Remote-write target for metrics. Default is homelab Prometheus
# (flatcar-media 192.168.100.100:9090) reachable via the WireGuard overlay.
# Override here if Prometheus moves or to point at a local test target.
PROMETHEUS_REMOTE_WRITE_URL=http://192.168.100.100:9090/api/v1/write
